# ── InkOnce environment ─────────────────────────────────────────────
# Copy to .env.local for dev; set all of these in the Vercel project.

# Higgsfield platform API (cloud.higgsfield.ai → dashboard → API keys)
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# Optional model overrides (see lib/higgsfield.ts for defaults)
# HF_MODEL_DRAFT=
# HF_MODEL_REFINE=
# HF_MODEL_STENCIL=

# Clerk (create a NEW Clerk app for InkOnce — do not reuse Almost Legal's)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Upstash Redis (create a NEW database for InkOnce)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vercel Blob (auto-injected when the Blob store is attached to the project)
BLOB_READ_WRITE_TOKEN=

# Shared secret Higgsfield must echo back on generation webhooks
HF_WEBHOOK_SECRET=

# Canonical origin, no trailing slash
NEXT_PUBLIC_SITE_URL=https://inkonce.com
